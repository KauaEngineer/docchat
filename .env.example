# =============================================================================
# Database (PostgreSQL via Prisma)
# =============================================================================
DATABASE_URL="postgresql://user:password@localhost:5432/chatbot_portfolio?schema=public"

# =============================================================================
# Better Auth
# =============================================================================
# Gere com: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
# Deve ser igual a BETTER_AUTH_URL — necessário no browser (prefixo NEXT_PUBLIC_)
NEXT_PUBLIC_BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth (https://console.cloud.google.com/apis/credentials)
# Authorized redirect URI: {BETTER_AUTH_URL}/api/auth/callback/google
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# =============================================================================
# AI Providers (Vercel AI SDK)
# =============================================================================
GOOGLE_GENERATIVE_AI_API_KEY=""
VERCEL_AI_API_KEY=""

# =============================================================================
# Cloudflare R2 (S3-compatible storage)
# =============================================================================
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET_NAME=""
R2_PUBLIC_URL=""

# =============================================================================
# Tools
# =============================================================================
# Tavily (https://tavily.com) — busca web. Free tier: 1000 requests/mês.
TAVILY_API_KEY=""
